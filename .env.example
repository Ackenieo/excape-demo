# ==========================================
# Flask 服务配置 (Server Configuration)
# ==========================================
FLASK_DEBUG=true
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=8888

# ==========================================
# 数据库配置 (Database Configuration)
# ==========================================
# SQLAlchemy 完整连接字符串
DATABASE_URL=postgresql://your_user:your_password@127.0.0.1:5433/escape

# PostgreSQL 详细凭证信息 (供参考及部分工具使用)
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=escape
POSTGRES_PORT=5433

# ==========================================
# 大语言模型配置 (LLM Configuration)
# ==========================================
# DeepSeek API 密钥，供 LangChain 调用
deepseek_api_key=your_deepseek_api_key_here

# ==========================================
# 头像上传配置 (Avatar Upload Configuration)
# ==========================================
AVATAR_UPLOAD_DIR=d:/WWWWokP/excape/uploads/avatars
AVATAR_UPLOAD_PUBLIC_BASE_URL=https://cdn.example.com
AVATAR_UPLOAD_ALLOWED_HOSTS=cdn.example.com
DEFAULT_PROFILE_AVATAR_URL=
